# ── Chain ─────────────────────────────────────────────────────────────────────
# Celo mainnet RPC (defaults to https://forno.celo.org if unset)
CELO_RPC_URL=https://forno.celo.org
CHAIN_ID=42220

# ── Agent wallet (deployer key = agent identity) ───────────────────────────────
# Private key of the wallet that deploys contracts AND acts as the AI agent.
# Used to: sign ERC-8004 Self Agent ID requests, broadcast agent-initiated txs.
AGENT_PRIVATE_KEY=0x_your_deployer_private_key

# Self Agent ID — populated by `npm run register:agent` after passport scan.
# Format: numeric NFT token ID e.g. 42
AGENT_SELF_ID=

# ── Deployed contract addresses ───────────────────────────────────────────────
# Copy from smartcontract/deployments/celo-mainnet.json after deploying.
USERNAME_REGISTRY_ADDRESS=0x3b89d7b4997db5645db2829523ed3e79e55a0f02
GROUP_REGISTRY_ADDRESS=0xee7ee3852663917a12ef95852a9fc4e092e45a31
COWRYPAY_ADDRESS=0x2b0d2f1dec9ab3e06668145d21ed17715e288350

# ── AI (OpenAI / Claude for intent parsing) ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Privy (server-side wallet creation for WhatsApp flow — optional) ──────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── LI.FI (cross-chain bridge + Earn vaults) ─────────────────────────────────
# Optional — without it requests still work but are rate-limited
LIFI_API_KEY=
# Shown in LI.FI analytics dashboard (identifies your integration)
LIFI_INTEGRATOR=sendpay

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
