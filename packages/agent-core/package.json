{
  "name": "@cowry/agent-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node scripts/build.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./agent/*.js": {
      "types": "./src/agent/*.ts",
      "import": "./src/agent/*.ts",
      "default": "./src/agent/*.ts"
    },
    "./chain/*.js": {
      "types": "./src/chain/*.ts",
      "import": "./src/chain/*.ts",
      "default": "./src/chain/*.ts"
    },
    "./deps/*.js": {
      "types": "./src/deps/*.ts",
      "import": "./src/deps/*.ts",
      "default": "./src/deps/*.ts"
    },
    "./lifi/*.js": {
      "types": "./src/lifi/*.ts",
      "import": "./src/lifi/*.ts",
      "default": "./src/lifi/*.ts"
    }
  },
  "dependencies": {
    "openai": "^4.73.0",
    "viem": "^2.47.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.6.3"
  }
}
