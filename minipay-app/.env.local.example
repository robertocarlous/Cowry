# Cowry AI agent backend URL
# Leave empty to use the Next.js /api/* proxy (recommended for local dev)
NEXT_PUBLIC_AGENT_URL=

# Celo RPC (defaults to forno)
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# LI.FI bridge (optional here — also read from ../ai-agent-service/.env on server start)
# LIFI_API_KEY=
# LIFI_INTEGRATOR=cowry

# Groq Whisper (voice notes — speech-to-text)
# GROQ_API_KEY=
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Etherscan unified API (transaction history — Celo via chainid=42220)
# Free key: https://etherscan.io/apis
# ETHERSCAN_API_KEY=
