# Celo mainnet deployer — must have CELO for gas
CELO_DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key

# Optional: override default RPC (defaults to https://forno.celo.org)
# CELO_RPC_URL=https://forno.celo.org

# Required for `npm run verify:celo-mainnet` on CeloScan
# Get a key at https://celoscan.io/apis
CELOSCAN_API_KEY=your_celoscan_api_key
