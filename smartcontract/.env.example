# ── Celo mainnet deployer ─────────────────────────────────────────────────────
# The wallet that deployed the contracts (must be the contract owner to call setOperator etc.)
# Must have CELO for gas. NEVER commit the real key — copy this file to .env and fill it in.
CELO_DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# ── Cowry AI agent wallet ─────────────────────────────────────────────────────
# The agent wallet registered as operator on CowryPay at deploy time.
# Derive from AGENT_PRIVATE_KEY or set explicitly.
AGENT_ADDRESS=0xYOUR_AGENT_WALLET_ADDRESS_HERE

# ── Optional overrides ────────────────────────────────────────────────────────
# Override default Celo RPC (defaults to https://forno.celo.org)
# CELO_RPC_URL=https://forno.celo.org

# CeloScan API key for contract verification (Sourcify works without this)
# Get one at https://celoscan.io/apis
# CELOSCAN_API_KEY=your_celoscan_api_key
